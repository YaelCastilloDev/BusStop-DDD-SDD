{
    "Logging": {
      "LogLevel": {
        "Default": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "AllowedHosts": "*",
    "Keycloak": {
      "AuthorizationUrl": "https://auth.yourdomain.com/realms/auth-demo/protocol/openid-connect/auth",
      "TokenUrl": "https://auth.yourdomain.com/realms/auth-demo/protocol/openid-connect/token"
    },
    "Authentication": {
      "MetadataAddress": "https://auth.yourdomain.com/realms/auth-demo/.well-known/openid-configuration",
      "ValidIssuer": "https://auth.yourdomain.com/realms/auth-demo",
      "Audience": "account"
    }
  }